{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://huibozi.github.io/claude-code-unified-research/policy.schema.json",
  "title": "Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "description",
    "scope",
    "priority",
    "allow_rules",
    "deny_rules",
    "ask_rules",
    "danger_filters",
    "audit_requirements"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "scope": {
      "type": "string"
    },
    "priority": {
      "type": "integer"
    },
    "allow_rules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "deny_rules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "ask_rules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "danger_filters": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "audit_requirements": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "routing_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "match",
          "target_agent",
          "enabled",
          "priority"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "match": {
            "type": "object"
          },
          "target_agent": {
            "type": "string"
          },
          "enabled": {
            "type": "boolean"
          },
          "priority": {
            "type": "integer"
          }
        }
      }
    },
    "adapter_notes": {
      "type": "object"
    }
  }
}
