{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://huibozi.github.io/claude-code-unified-research/policy.schema.json",
  "title": "Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "description",
    "scope",
    "priority",
    "allow_rules",
    "deny_rules",
    "ask_rules",
    "danger_filters",
    "audit_requirements"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "scope": {
      "type": "string"
    },
    "priority": {
      "type": "integer"
    },
    "allow_rules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "deny_rules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "ask_rules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "danger_filters": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "audit_requirements": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "routing_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "match",
          "action",
          "enabled",
          "priority"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "match": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "channel"
            ],
            "properties": {
              "channel": {
                "type": "string"
              },
              "account": {
                "type": "string"
              },
              "pattern": {
                "type": "string"
              },
              "pattern_mode": {
                "type": "string",
                "enum": [
                  "literal",
                  "glob",
                  "regex"
                ]
              },
              "context": {
                "type": "string",
                "enum": [
                  "dm",
                  "group",
                  "all"
                ]
              }
            }
          },
          "action": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "type",
              "agent_id"
            ],
            "properties": {
              "type": {
                "type": "string",
                "const": "forward_to_agent"
              },
              "agent_id": {
                "type": "string"
              }
            }
          },
          "enabled": {
            "type": "boolean"
          },
          "priority": {
            "type": "integer"
          }
        }
      }
    },
    "adapter_notes": {
      "type": "object"
    }
  }
}
